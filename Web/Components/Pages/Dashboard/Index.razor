@page "/"
@rendermode InteractiveServer
@inject StoryLibraryService LibraryService
@inject NavigationManager Navigation

<PageTitle>Dashboard - Narratum</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24">
    <FluentText Block="true" Size="TextSize.Size900" Weight="TextWeight.Bold">✨ Bienvenue sur Narratum</FluentText>

    <FluentCard>
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16">
            <FluentButton Appearance="ButtonAppearance.Primary" @onclick='() => this.Navigation.NavigateTo("/wizard")' Style="flex: 1;">
                ➕ Créer une nouvelle histoire
            </FluentButton>
            <FluentButton Appearance="ButtonAppearance.Default" @onclick='() => this.Navigation.NavigateTo("/library")' Style="flex: 1;">
                📚 Voir toutes mes histoires
            </FluentButton>
        </FluentStack>
    </FluentCard>

    <FluentText Block="true" Size="TextSize.Size600" Weight="TextWeight.Semibold">Histoires récentes</FluentText>

    @if (this.recentStories == null)
    {
        <FluentSpinner />
    }
    else if (!this.recentStories.Any())
    {
        <FluentMessageBar Intent="MessageBarIntent.Info">
            Aucune histoire. Créez-en une pour commencer !
        </FluentMessageBar>
    }
    else
    {
        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" HorizontalGap="16">
            @foreach (var story in this.recentStories)
            {
                <FluentCard Style="width: 300px; cursor: pointer;" @onclick="@(() => this.OpenStory(story.SlotName))">
                    <FluentText Block="true" Size="TextSize.Size500" Weight="TextWeight.Semibold">@story.DisplayName</FluentText>
                    <FluentText Block="true" Size="TextSize.Size300">Genre: @story.GenreStyle</FluentText>
                    <FluentText Block="true" Size="TextSize.Size300">Pages: @story.PageCount</FluentText>
                    <FluentText Block="true" Size="TextSize.Size300">
                        Modifié: @story.LastModified.ToString("dd/MM/yyyy")
                    </FluentText>
                </FluentCard>
            }
        </FluentStack>
    }
</FluentStack>

@code {
    private List<StoryEntry>? recentStories;

    protected override async Task OnInitializedAsync()
    {
        var allStories = await this.LibraryService.ListStoriesAsync();
        this.recentStories = allStories.Take(6).ToList();
    }

    private void OpenStory(string slotName)
    {
        this.Navigation.NavigateTo($"/reader/{slotName}");
    }
}
