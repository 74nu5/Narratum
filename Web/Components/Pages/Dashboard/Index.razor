@page "/"
@rendermode InteractiveServer
@inject StoryLibraryService LibraryService
@inject NavigationManager Navigation

<PageTitle>Dashboard - Narratum</PageTitle>

<div style="max-width:1080px;margin:0 auto;padding:64px 28px 72px">

    <div style="margin-bottom:44px">
        <div class="kicker" style="margin-bottom:14px">Générateur d'histoires</div>
        <h1 style="font-size:56px;line-height:1.02;margin-bottom:14px">Bienvenue sur <span style="font-style:italic">Narratum</span></h1>
        <p style="margin:0;max-width:560px;font-family:var(--serif);font-size:19px;line-height:1.6;color:var(--text-2)">
            Écrivez, page après page, des récits qui se souviennent d'eux-mêmes. Reprenez une histoire en cours,
            ou commencez une nouvelle aventure.
        </p>
    </div>

    <div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:56px">
        <a class="btn btn-accent" href="/wizard" style="padding:14px 26px;border-radius:12px;font-size:15px">＋ Créer une nouvelle histoire</a>
        <a class="btn btn-ghost" href="/library" style="padding:14px 26px;border-radius:12px;font-size:15px">📚 Voir toutes mes histoires</a>
    </div>

    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:22px">
        <h2 style="font-size:28px">Histoires récentes</h2>
        <span class="mono" style="font-size:12px;color:var(--text-3)">@(_recentStories?.Count ?? 0) histoire@(_recentStories?.Count == 1 ? "" : "s")</span>
    </div>

    @if (_recentStories is null)
    {
        <div class="spinner" style="margin:32px auto"></div>
    }
    else if (_recentStories.Count == 0)
    {
        <div class="card" style="padding:40px;text-align:center;font-family:var(--serif);font-size:17px;color:var(--text-3)">
            Aucune histoire pour l'instant. Créez-en une pour commencer.
        </div>
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px">
            @foreach (var story in _recentStories)
            {
                <div class="story-card">
                    <span class="story-card-rule" style="background:@StoryVisuals.Accent(story.GenreStyle)"></span>
                    <div style="font-size:26px;margin-bottom:12px">@StoryVisuals.Icon(story.GenreStyle)</div>
                    <div style="font-family:var(--serif);font-size:21px;font-weight:600;color:var(--text);line-height:1.2;margin-bottom:12px">@story.DisplayName</div>
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px">
                        <span class="chip">@story.GenreStyle</span>
                        <span style="font-size:12.5px;color:var(--text-3)">@story.PageCount page@(story.PageCount == 1 ? "" : "s")</span>
                    </div>
                    <div style="margin-top:auto;padding-top:12px;border-top:1px solid var(--border)">
                        <div class="mono" style="font-size:11px;color:var(--text-3);margin-bottom:10px">Modifié @story.LastModified.ToString("dd/MM/yyyy")</div>
                        <div style="display:flex;gap:8px">
                            <a class="btn btn-soft btn-sm" href="@($"/reader/{story.SlotName}")" style="flex:1">📖 Lire</a>
                            <a class="btn btn-accent btn-sm" href="@($"/generation/{story.SlotName}")" style="flex:1">▶ Reprendre</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<StoryEntry>? _recentStories;

    protected override async Task OnInitializedAsync()
    {
        var all = await LibraryService.ListStoriesAsync();
        _recentStories = all.Take(6).ToList();
    }
}
