@page "/generation/{SlotName}"
@rendermode InteractiveServer
@inject IGenerationService GenService
@inject StoryLibraryService LibraryService
@inject NavigationManager Navigation
@inject ExpertModeService ExpertMode
@inject ModelCatalogService ModelCatalog
@inject AzureFoundryState AzureState
@inject Narratum.Orchestration.Llm.ILlmClient LlmClient
@using Narratum.Orchestration.Models
@using Narratum.Llm.Azure
@implements IDisposable

<PageTitle>Génération - Narratum</PageTitle>

<div class="gen-shell">

    @* LEFT: persistent library sidebar *@
    <aside class="gen-side">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:0 6px;margin-bottom:16px">
            <span class="eyebrow">Bibliothèque</span>
            <span class="mono" style="font-size:11px;color:var(--text-3)">@_library.Count</span>
        </div>
        <a class="btn btn-accent btn-block" href="/wizard" style="border-radius:10px;padding:11px;margin-bottom:18px">＋ Nouvelle histoire</a>
        <div style="display:flex;flex-direction:column;gap:4px">
            @foreach (var s in _library)
            {
                <a class="side-story @(s.SlotName == SlotName ? "is-active" : null)" href="@($"/generation/{s.SlotName}")">
                    <span style="font-size:15px;flex:none;opacity:.85">@StoryVisuals.Icon(s.GenreStyle)</span>
                    <span style="flex:1;min-width:0">
                        <span style="display:block;font-size:14px;font-weight:@(s.SlotName == SlotName ? 700 : 500);color:@(s.SlotName == SlotName ? "var(--text)" : "var(--text-2)");white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@s.DisplayName</span>
                        <span style="display:block;font-size:11.5px;color:var(--text-3)">@s.PageCount page@(s.PageCount == 1 ? "" : "s")</span>
                    </span>
                </a>
            }
        </div>
    </aside>

    @* RIGHT: story *@
    <div class="gen-body">
        <div class="gen-content">

            @* Title block *@
            <div style="text-align:center;margin-bottom:34px">
                @if (!string.IsNullOrWhiteSpace(_genre))
                {
                    <div class="kicker" style="margin-bottom:12px">@_genre</div>
                }
                <h1 style="font-size:52px;line-height:1.05">@_displayTitle</h1>
                @if (!string.IsNullOrEmpty(_currentPageModel) && !_isGenerating)
                {
                    <div style="font-size:12.5px;color:var(--text-3);margin-top:12px">Généré avec <strong style="color:var(--text-2)">@ModelBadge(_currentPageModel)</strong>@(string.IsNullOrEmpty(_currentPageImage) ? "" : " · illustration")</div>
                }
            </div>

            @* Timeline: progress bar with prev / next *@
            @if (_pageHistory.Any())
            {
                <div style="max-width:560px;margin:0 auto 44px">
                    <div style="display:flex;align-items:center;gap:14px">
                        <button class="icon-btn" title="Page précédente" @onclick="GoPrev" disabled="@(AtFirst || _isGenerating)">◀</button>
                        <div style="flex:1">
                            <div class="progress"><span style="width:@(ProgressPct)%"></span></div>
                            <div style="display:flex;justify-content:space-between;margin-top:7px" class="mono">
                                <span style="font-size:10.5px;color:var(--text-3)">Début</span>
                                <span style="font-size:10.5px;color:var(--accent);font-weight:600">Page @_currentPageIndex / @(_pageHistory.Max())</span>
                                <span style="font-size:10.5px;color:var(--text-3)">Fin</span>
                            </div>
                        </div>
                        <button class="icon-btn" title="Page suivante" @onclick="GoNext" disabled="@(AtLast || _isGenerating)">▶</button>
                    </div>
                </div>
            }

            @* Reading: badge + image + prose *@
            <div style="min-height:200px">
                @if (_isGenerating && string.IsNullOrEmpty(_currentNarrative))
                {
                    <div style="display:flex;flex-direction:column;align-items:center;gap:14px;padding:60px 0">
                        <div class="spinner"></div>
                        <div style="font-size:13px;color:var(--text-3)">Génération avec <strong style="color:var(--text-2)">@ModelBadge(_selectedModel)</strong>…</div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(_currentNarrative))
                {
                    <article class="gen-hero @(string.IsNullOrEmpty(_currentPageImage) ? "noimage" : null)">
                        @if (!string.IsNullOrEmpty(_currentPageImage))
                        {
                            <figure style="margin:0;position:sticky;top:88px">
                                <div style="position:relative;border-radius:4px;overflow:hidden;border:1px solid var(--border-strong);box-shadow:var(--shadow)">
                                    <img src="@_currentPageImage" alt="Illustration de la page" style="display:block;width:100%;aspect-ratio:1;object-fit:cover" />
                                    <span class="chip" style="position:absolute;top:10px;left:10px;background:color-mix(in srgb,var(--bg) 78%,transparent);backdrop-filter:blur(4px)">Planche</span>
                                </div>
                                <figcaption class="mono" style="font-size:10.5px;color:var(--text-3);margin-top:9px">@SlotName / page @_currentPageIndex</figcaption>
                                <button class="btn btn-quiet btn-sm" style="padding-left:0;margin-top:2px" @onclick="OpenImagePromptAsync" disabled="@(_regeneratingImage || _isGenerating)">
                                    @(_regeneratingImage ? "↻ Régénération…" : "↻ Régénérer l'illustration")
                                </button>
                            </figure>
                        }
                        <div>
                            @if (_editing)
                            {
                                <textarea class="field" @bind="_editText"
                                          style="min-height:460px;font-family:var(--serif);font-size:17px;line-height:1.7"></textarea>
                                <div style="display:flex;gap:8px;margin-top:12px">
                                    <button class="btn btn-accent btn-sm" @onclick="SaveEditAsync">Enregistrer</button>
                                    <button class="btn btn-soft btn-sm" @onclick="() => _editing = false">Annuler</button>
                                </div>
                            }
                            else
                            {
                                <div class="prose dropcap">@_currentNarrative@(_isGenerating ? "▋" : string.Empty)</div>
                            }

                            @if (string.IsNullOrEmpty(_currentPageImage) && !_isGenerating && !_editing)
                            {
                                <button class="btn btn-dashed btn-sm" style="margin-top:22px" @onclick="OpenImagePromptAsync" disabled="@_regeneratingImage">
                                    @(_regeneratingImage ? "🖼 Génération de l'illustration…" : "🖼 Générer une illustration")
                                </button>
                            }
                            @if (!string.IsNullOrEmpty(_imageError))
                            {
                                <div class="msg msg-error" style="margin-top:12px">@_imageError</div>
                            }
                        </div>
                    </article>
                }
                else
                {
                    <div class="card" style="padding:40px;text-align:center;font-family:var(--serif);font-size:17px;color:var(--text-3)">
                        Aucune page générée. Composez la première page ci-dessous.
                    </div>
                }
            </div>

            @* The visual prompt is the author's to shape — shown and editable before rendering. *@
            @if (_imagePromptOpen)
            {
                <div class="card" style="padding:16px 18px;margin-top:18px">
                    <label class="fld-label">Prompt de l'illustration</label>
                    @if (_loadingImagePrompt)
                    {
                        <div style="display:flex;align-items:center;gap:10px;color:var(--text-3);font-size:13px">
                            <div class="spinner spinner-sm"></div> Préparation du prompt…
                        </div>
                    }
                    else
                    {
                        <textarea class="field" @bind="_imagePrompt" style="min-height:110px"
                                  placeholder="Décrivez la scène à illustrer : cadre, décor, personnages, lumière…"></textarea>
                        <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">
                            <button class="btn btn-accent btn-sm" @onclick="ConfirmRegenerateImageAsync"
                                    disabled="@(_regeneratingImage || string.IsNullOrWhiteSpace(_imagePrompt))">
                                @(_regeneratingImage ? "✨ Génération…" : "✨ Générer l'illustration")
                            </button>
                            <button class="btn btn-soft btn-sm" @onclick="() => _imagePromptOpen = false" disabled="@_regeneratingImage">Annuler</button>
                            <button class="btn btn-quiet btn-sm" @onclick="SuggestImagePromptAsync" disabled="@_regeneratingImage">↻ Reproposer un prompt</button>
                        </div>
                    }
                </div>
            }

            @* Page-level actions: correct it, rewrite it, or take it back. *@
            @if (!_isGenerating && !_editing && !string.IsNullOrEmpty(_currentNarrative) && _currentPageIndex > 0)
            {
                <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:22px;justify-content:center">
                    <button class="btn btn-quiet btn-sm" @onclick="StartEdit">✎ Éditer le texte</button>
                    <button class="btn btn-quiet btn-sm" @onclick="RequestRegeneratePage">↻ Régénérer cette page</button>
                    @if (IsAtTip)
                    {
                        <button class="btn btn-quiet btn-sm" @onclick="RequestDeleteLastPage">🗑 Supprimer cette page</button>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="msg msg-error" style="margin-top:24px">@_errorMessage</div>
            }

            @* Secrets + characters *@
            @if (!_isGenerating && (VisibleSecrets.Count > 0 || _characters.Count > 0))
            {
                <div class="gen-2col-secrets">
                    <div>
                        <div class="eyebrow" style="margin-bottom:12px">
                            🔑 Secrets révélés@(ExpertMode.IsExpertModeEnabled ? " + cachés" : null)
                        </div>
                        @if (VisibleSecrets.Count > 0)
                        {
                            <div style="display:flex;flex-direction:column;gap:10px">
                                @foreach (var secret in VisibleSecrets)
                                {
                                    <div class="secret @(secret.IsRevealed ? null : "secret-hidden")">
                                        <span class="chip-secret" style="margin-bottom:8px">@secret.Category@(secret.IsRevealed ? null : " · caché")</span>
                                        <p>@secret.Content</p>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div style="font-size:13.5px;color:var(--text-3);font-style:italic">Aucun secret révélé pour l'instant.</div>
                        }
                    </div>
                    <div>
                        <div class="eyebrow" style="margin-bottom:12px">👥 Personnages</div>
                        <div style="display:flex;flex-direction:column;gap:10px">
                            @foreach (var character in _characters)
                            {
                                <div class="person">
                                    <div class="person-head">
                                        <span class="person-name">@character.Name</span>
                                        @if (!string.IsNullOrWhiteSpace(character.Role))
                                        {
                                            <span class="badge-role">@character.Role</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(character.Description))
                                    {
                                        <div class="person-desc">@character.Description</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(character.Evolution))
                                    {
                                        <div class="person-evo">↝ @character.Evolution</div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            @* Choices + composer *@
            <section class="gen-2col-actions">
                <div>
                    <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:18px;flex-wrap:wrap">
                        <h2 style="font-size:26px">Que faites-vous ?</h2>
                        @if (!_isGenerating && _choices.Count > 0)
                        {
                            <button class="btn btn-quiet btn-sm" @onclick="RegenerateChoicesAsync" disabled="@_regeneratingChoices">
                                @(_regeneratingChoices ? "↻ …" : "↻ Autres choix")
                            </button>
                        }
                    </div>
                    @if (!_isGenerating && _choices.Count > 0)
                    {
                        <div style="display:flex;flex-direction:column;gap:12px">
                            @{ var n = 0; }
                            @foreach (var choice in _choices)
                            {
                                n++;
                                <button class="choice" @onclick="() => RequestGenerate(choice.Text)" disabled="@_isGenerating">
                                    <span class="choice-num">@Roman(n)</span>
                                    <span class="choice-body">
                                        <span class="choice-title">@choice.Text</span>
                                        <span class="choice-desc">@choice.Description</span>
                                    </span>
                                    <span class="choice-arrow">→</span>
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <div style="font-size:14px;color:var(--text-3);font-style:italic">
                            @(_isGenerating ? "Génération en cours…" : "Écrivez la suite pour découvrir de nouveaux choix.")
                        </div>
                    }
                </div>

                <div class="card" style="padding:20px 20px 22px">
                    <h2 style="font-size:20px;margin-bottom:4px">Écrire la suite</h2>
                    <p style="margin:0 0 18px;font-size:12.5px;color:var(--text-3)">Ou laissez le récit continuer seul.</p>

                    @if (_subscriptions.Count > 0)
                    {
                        <label class="fld-label">Souscription</label>
                        <select class="field" style="margin-bottom:14px" @bind="_currentSubscription" @bind:after="OnSubscriptionChanged" disabled="@(_subscriptions.Count < 2)">
                            @foreach (var s in _subscriptions)
                            {
                                <option value="@s.SubscriptionId">☁ @s.DisplayName</option>
                            }
                        </select>
                    }

                    <label class="fld-label">Modèle &amp; image</label>
                    <select class="field" style="margin-bottom:6px" @bind="_selectedModel">
                        @foreach (var m in _models)
                        {
                            <option value="@m.Id">@m.Label</option>
                        }
                    </select>
                    @if (_imageModels.Count > 0)
                    {
                        <select class="field" style="margin-bottom:6px" @bind="_selectedImageModel">
                            @foreach (var m in _imageModelOptions)
                            {
                                <option value="@m.Id">@m.Label</option>
                            }
                        </select>
                    }
                    <div style="font-size:12px;color:var(--text-3);margin:2px 0 16px">▸ @ModelBadge(_selectedModel)</div>

                    <label class="fld-label">Que se passe-t-il ensuite ?</label>
                    <textarea class="field" style="min-height:78px;margin-bottom:16px" @bind="_userIntent" @bind:event="oninput"
                              placeholder="Ex : Les personnages découvrent une porte secrète…"></textarea>

                    <button class="btn btn-accent btn-block" @onclick="() => RequestGenerate(_userIntent)" disabled="@(_isGenerating || string.IsNullOrWhiteSpace(_userIntent))">✦ Générer la suite</button>
                    <button class="btn btn-ghost btn-block" style="margin-top:8px" @onclick="() => RequestGenerate(AutoContinueIntent)" disabled="@_isGenerating">↷ Continuer seul</button>
                    <button class="btn btn-ghost btn-block" style="margin-top:8px" @onclick="StartNewRunAsync"
                            disabled="@(_isGenerating || _duplicating)" title="Rejouer ce même univers dans une nouvelle partie">
                        ⎘ Nouvelle partie
                    </button>
                    <div style="display:flex;gap:6px;margin-top:8px">
                        <a class="btn btn-quiet btn-sm" href="@($"/export/{SlotName}/epub")" style="flex:1">⤓ EPUB</a>
                        <a class="btn btn-quiet btn-sm" href="@($"/export/{SlotName}/markdown")" style="flex:1">⤓ Markdown</a>
                    </div>
                    <a class="btn btn-quiet btn-block" href="/" style="margin-top:2px">← Retour au tableau de bord</a>
                </div>
            </section>

            @* Expert: backstage trigger *@
            @if (ExpertMode.IsExpertModeEnabled && BackstageTraces.Count > 0)
            {
                <div style="display:flex;justify-content:center;margin-top:48px">
                    <button class="btn btn-dashed" style="border-radius:999px" @onclick="() => _backstageOpen = true">🔍 Voir les coulisses des agents</button>
                </div>
            }
        </div>
    </div>
</div>

@* Every destructive page action funnels through the same confirmation. *@
@if (_confirm is not null)
{
    <div class="overlay" @onclick="() => _confirm = null">
        <div class="modal" style="max-width:440px;padding:26px 26px 22px" @onclick:stopPropagation="true">
            <div class="modal-title" style="margin-bottom:8px">@_confirm.Title</div>
            <p style="margin:0 0 22px;font-size:14px;line-height:1.55;color:var(--text-2)">@_confirm.Body</p>
            <div style="display:flex;gap:10px;justify-content:flex-end">
                <button class="btn btn-soft" @onclick="() => _confirm = null">Annuler</button>
                <button class="btn btn-danger" @onclick="RunConfirmAsync">@_confirm.ConfirmLabel</button>
            </div>
        </div>
    </div>
}

@* Backstage modal (expert) *@
@if (_backstageOpen && ExpertMode.IsExpertModeEnabled)
{
    <div class="overlay overlay-top" @onclick="() => _backstageOpen = false">
        <div class="modal" style="max-width:780px;overflow:hidden" @onclick:stopPropagation="true">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;padding:24px 28px 18px;border-bottom:1px solid var(--border)">
                <div>
                    <div class="modal-title">Coulisses des agents</div>
                    <div style="font-size:13px;color:var(--text-2);margin-top:5px;max-width:520px;line-height:1.5">Ce que chaque agent spécialisé a produit pour cette page. Le lecteur ne voit que la prose du Narrateur.</div>
                </div>
                <button class="icon-btn" @onclick="() => _backstageOpen = false" style="font-size:19px">×</button>
            </div>
            <div style="padding:16px 28px 28px;max-height:68vh;overflow:auto;display:flex;flex-direction:column;gap:9px">
                @foreach (var trace in BackstageTraces)
                {
                    <details class="trace">
                        <summary>
                            <span class="trace-name">@trace.Agent</span>
                            <span class="trace-role">@trace.Role</span>
                            <span class="trace-ms">@trace.DurationMs.ToString("F0") ms</span>
                        </summary>
                        <div class="trace-body">@trace.Output</div>
                    </details>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string SlotName { get; set; } = string.Empty;

    /// Opening action handed over by the wizard: page 1 is generated on arrival.
    [SupplyParameterFromQuery(Name = "intent")]
    public string? OpeningIntent { get; set; }

    private List<StoryEntry> _library = new();
    private string? _loadedSlot;
    private string? _autoStartedFor;
    private string? _genre;
    private bool _backstageOpen;
    private ConfirmPrompt? _confirm;
    private bool _regeneratingImage;
    private bool _regeneratingChoices;
    private string? _imageError;
    private bool _editing;
    private string _editText = string.Empty;
    private bool _duplicating;
    private bool _imagePromptOpen;
    private bool _loadingImagePrompt;
    private string _imagePrompt = string.Empty;
    private string _currentPageIntent = string.Empty;

    /// A pending destructive action, shown in the confirmation modal.
    private sealed record ConfirmPrompt(string Title, string Body, string ConfirmLabel, Func<Task> Action);

    // Used by "Continuer seul": the service requires a non-empty intent, so hand the narrator
    // an explicit "just keep going" instruction rather than loosening the contract.
    private const string AutoContinueIntent = "Poursuis naturellement le récit, sans changer de direction.";

    private List<int> _pageHistory = new();
    private int _currentPageIndex = 0;
    private string _currentNarrative = string.Empty;
    private string _userIntent = string.Empty;
    private bool _isGenerating = false;
    private string _errorMessage = string.Empty;
    private string _displayTitle = string.Empty;
    private IReadOnlyList<AgentTraceInfo> _agentTraces = Array.Empty<AgentTraceInfo>();
    private IReadOnlyDictionary<int, string?> _pageModels = new Dictionary<int, string?>();
    private IReadOnlyList<StoryChoice> _choices = Array.Empty<StoryChoice>();
    private IReadOnlyList<CharacterProfile> _characters = Array.Empty<CharacterProfile>();
    private IReadOnlyList<StorySecret> _secrets = Array.Empty<StorySecret>();
    private IReadOnlyList<ModelOption> _models = ModelSelectionService.AvailableModels;
    private IReadOnlyList<ModelOption> _localModels = Array.Empty<ModelOption>();
    private string _selectedModel = ModelSelectionService.AvailableModels[0].Id;
    private string? _currentPageModel;
    private IReadOnlyList<ModelOption> _imageModels = Array.Empty<ModelOption>();
    private string _selectedImageModel = string.Empty; // "" = no image
    private string? _currentPageImage;

    // Image dropdown = a "no image" sentinel followed by the available image models.
    private IReadOnlyList<ModelOption> _imageModelOptions => [new ModelOption(string.Empty, "🚫 Sans image"), .. _imageModels];
    private IReadOnlyList<AzureSubscriptionInfo> _subscriptions = Array.Empty<AzureSubscriptionInfo>();
    private string? _currentSubscription;

    // The Narrator's trace is the prose already on screen — redundant backstage.
    private const string NarratorAgent = "Narrateur";
    private IReadOnlyList<AgentTraceInfo> BackstageTraces =>
        [.. _agentTraces.Where(t => !string.Equals(t.Agent, NarratorAgent, StringComparison.OrdinalIgnoreCase))];

    // Hidden secrets are the author's material: surface them in Expert mode only.
    private IReadOnlyList<StorySecret> VisibleSecrets =>
        ExpertMode.IsExpertModeEnabled ? _secrets : [.. _secrets.Where(s => s.IsRevealed)];

    // Generating from a page that is not the tip rewrites the story from there.
    private bool IsAtTip => _pageHistory.Count == 0 || _currentPageIndex >= _pageHistory.Max();
    private int PagesToDrop => _pageHistory.Count == 0 ? 0 : Math.Max(0, _pageHistory.Max() - _currentPageIndex);

    // Timeline navigation over the sorted page history.
    private int CurrentPos => _pageHistory.IndexOf(_currentPageIndex);
    private int TotalPages => _pageHistory.Count;
    private int ProgressPct => TotalPages <= 1 ? 100 : (int)Math.Round((double)Math.Max(0, CurrentPos) / (TotalPages - 1) * 100);
    private bool AtFirst => CurrentPos <= 0;
    private bool AtLast => CurrentPos >= TotalPages - 1;

    private static string Roman(int n) => n switch { 1 => "I", 2 => "II", 3 => "III", 4 => "IV", 5 => "V", _ => n.ToString() };

    // Human-readable "provider · model" for a stored model id (local Foundry or azure:*).
    private string ModelBadge(string? modelId) => ModelDisplay.Badge(modelId, _models);

    private string? PageModel(int pageIndex) => _pageModels.GetValueOrDefault(pageIndex);

    protected override void OnInitialized()
    {
        // Re-render when the Expert toggle (in the layout) changes.
        ExpertMode.OnExpertModeToggled += HandleExpertToggled;
    }

    // Picking another story in the sidebar only changes the route parameter, and Blazor reuses
    // this component instance — so the story must be (re)loaded here. Doing it in
    // OnInitializedAsync would leave the previous story's title and prose on screen.
    protected override async Task OnParametersSetAsync()
    {
        if (_loadedSlot == SlotName)
            return;

        _loadedSlot = SlotName;
        await LoadStoryAsync();

        // Arriving from the wizard with an opening action: write page 1 immediately, then drop
        // the query string so a refresh doesn't generate it a second time.
        if (!string.IsNullOrWhiteSpace(OpeningIntent) && _autoStartedFor != SlotName)
        {
            _autoStartedFor = SlotName;
            var opening = OpeningIntent;
            await RunGenerationAsync(opening);
            Navigation.NavigateTo($"/generation/{SlotName}", replace: true);
        }
    }

    private async Task LoadStoryAsync()
    {
        // Drop everything tied to the story we were on.
        _currentNarrative = string.Empty;
        _currentPageImage = null;
        _currentPageModel = null;
        _choices = Array.Empty<StoryChoice>();
        _characters = Array.Empty<CharacterProfile>();
        _secrets = Array.Empty<StorySecret>();
        _agentTraces = Array.Empty<AgentTraceInfo>();
        _pageHistory = new();
        _currentPageIndex = 0;
        _errorMessage = string.Empty;
        _imageError = null;
        _userIntent = string.Empty;
        _backstageOpen = false;
        _confirm = null;
        _editing = false;
        _currentPageIntent = string.Empty;
        _imagePromptOpen = false;
        _imagePrompt = string.Empty;

        _library = await LibraryService.ListStoriesAsync();
        _genre = _library.FirstOrDefault(s => s.SlotName == SlotName)?.GenreStyle;
        _displayTitle = await GenService.GetDisplayNameAsync(SlotName);
        _localModels = await ModelCatalog.GetModelsAsync(LlmClient);
        _subscriptions = await AzureState.GetSubscriptionsAsync();
        _currentSubscription = AzureState.CurrentSubscriptionId;
        await RebuildModelListAsync();
        _imageModels = await AzureState.GetAzureImageModelsAsync();
        _selectedModel = _models.FirstOrDefault()?.Id ?? _selectedModel;

        await LoadPageHistory();

        // Load latest page if exists
        if (_pageHistory.Any())
        {
            _currentPageIndex = _pageHistory.Max();
            await LoadPage(_currentPageIndex);
        }
    }

    // The stored model may be an alias (older story) while the catalogue uses concrete
    // variant ids — map it to a real option, else keep the first available model.
    private string ResolveSelectedModel(string stored)
    {
        if (_models.Any(m => m.Id == stored)) return stored;
        var byAlias = _models.FirstOrDefault(m => m.Id.StartsWith(stored, StringComparison.OrdinalIgnoreCase));
        return byAlias?.Id ?? _models.FirstOrDefault()?.Id ?? stored;
    }

    // Merge local Foundry models with the current Azure subscription's chat deployments.
    private async Task RebuildModelListAsync()
    {
        var azureModels = await AzureState.GetAzureModelsAsync();
        _models = [.. _localModels, .. azureModels];
        _imageModels = await AzureState.GetAzureImageModelsAsync();
    }

    private async Task LoadImage(int pageIndex)
    {
        _currentPageImage = await GenService.GetPageImageAsync(SlotName, pageIndex);
    }

    private async Task OnSubscriptionChanged()
    {
        if (string.IsNullOrEmpty(_currentSubscription))
            return;

        AzureState.SetCurrentSubscription(_currentSubscription);
        await RebuildModelListAsync();
    }

    private void HandleExpertToggled() => InvokeAsync(StateHasChanged);

    public void Dispose() => ExpertMode.OnExpertModeToggled -= HandleExpertToggled;

    private async Task LoadTraces(int pageIndex) => _agentTraces = await GenService.GetAgentTraceAsync(SlotName, pageIndex);
    private async Task LoadChoices(int pageIndex) => _choices = await GenService.GetPageChoicesAsync(SlotName, pageIndex);
    private async Task LoadCharacters(int pageIndex) => _characters = await GenService.GetPageCharactersAsync(SlotName, pageIndex);
    private async Task LoadSecrets(int pageIndex) => _secrets = await GenService.GetPageSecretsAsync(SlotName, pageIndex);

    /// Entry point for every generation trigger (compose, a choice, or "continuer seul").
    /// Guards the case where the author went back: rewriting from there drops the rest.
    private async Task RequestGenerate(string intent)
    {
        if (string.IsNullOrWhiteSpace(intent) || _isGenerating)
            return;

        if (!IsAtTip)
        {
            var from = _currentPageIndex;
            _confirm = new ConfirmPrompt(
                "Réécrire à partir de cette page ?",
                $"Vous êtes revenu sur la page {from}. Générer une suite ici supprimera définitivement "
                + $"{PagesToDrop} page{(PagesToDrop > 1 ? "s" : "")} ({from + 1} à {_pageHistory.Max()}). "
                + "Cette action est irréversible.",
                "Supprimer et générer",
                async () =>
                {
                    await GenService.TruncateAfterAsync(SlotName, from);
                    await LoadPageHistory();
                    await RunGenerationAsync(intent);
                });
            return;
        }

        await RunGenerationAsync(intent);
    }

    private async Task RunConfirmAsync()
    {
        var prompt = _confirm;
        _confirm = null;
        if (prompt is not null)
            await prompt.Action();
    }

    /// Rewrites the page on screen: drop it (and anything after) and replay its own intent.
    private void RequestRegeneratePage()
    {
        if (_currentPageIndex <= 0)
            return;

        var index = _currentPageIndex;
        var intent = string.IsNullOrWhiteSpace(_currentPageIntent) ? AutoContinueIntent : _currentPageIntent;
        var following = _pageHistory.Max() - index;

        _confirm = new ConfirmPrompt(
            "Régénérer cette page ?",
            $"La page {index} sera réécrite à partir de la même intention."
            + (following > 0 ? $" Les {following} page{(following > 1 ? "s" : "")} suivante{(following > 1 ? "s" : "")} seront supprimées." : string.Empty)
            + " Cette action est irréversible.",
            "Régénérer",
            async () =>
            {
                await GenService.TruncateAfterAsync(SlotName, index - 1);
                await LoadPageHistory();
                await RunGenerationAsync(intent);
            });
    }

    /// Takes back the last page — the undo for a generation that went wrong.
    private void RequestDeleteLastPage()
    {
        var last = _pageHistory.Count > 0 ? _pageHistory.Max() : 0;
        if (last <= 0)
            return;

        _confirm = new ConfirmPrompt(
            "Supprimer cette page ?",
            $"La page {last} sera définitivement supprimée et l'histoire reviendra à la page {last - 1}. "
            + "Cette action est irréversible.",
            "Supprimer",
            async () =>
            {
                await GenService.TruncateAfterAsync(SlotName, last - 1);
                await LoadPageHistory();
                if (_pageHistory.Count > 0)
                    await LoadPage(_pageHistory.Max());
                _library = await LibraryService.ListStoriesAsync();
            });
    }

    /// Clones this universe into a fresh run and replays its opening action there.
    private async Task StartNewRunAsync()
    {
        _duplicating = true;
        try
        {
            var result = await GenService.DuplicateStoryAsync(SlotName);
            if (result is Narratum.Core.Result<StoryRun>.Success success)
            {
                var run = success.Value;
                Navigation.NavigateTo(string.IsNullOrWhiteSpace(run.OpeningIntent)
                    ? $"/generation/{run.SlotName}"
                    : $"/generation/{run.SlotName}?intent={Uri.EscapeDataString(run.OpeningIntent)}");
            }
            else if (result is Narratum.Core.Result<StoryRun>.Failure failure)
            {
                _errorMessage = failure.Message;
            }
        }
        finally
        {
            _duplicating = false;
        }
    }

    private void StartEdit()
    {
        _editText = _currentNarrative;
        _editing = true;
    }

    private async Task SaveEditAsync()
    {
        await GenService.UpdatePageTextAsync(SlotName, _currentPageIndex, _editText);
        _currentNarrative = _editText;
        _editing = false;
    }

    private async Task RegenerateChoicesAsync()
    {
        _regeneratingChoices = true;
        try
        {
            var result = await GenService.RegeneratePageChoicesAsync(SlotName, _currentPageIndex, _selectedModel);
            if (result is Narratum.Core.Result<IReadOnlyList<StoryChoice>>.Success success)
                _choices = success.Value;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            _regeneratingChoices = false;
        }
    }

    /// Opens the prompt editor, pre-filled with the prompt behind the current illustration
    /// (or a freshly suggested one). Deriving it can call the LLM, hence the loading state.
    private async Task OpenImagePromptAsync()
    {
        _imageError = null;

        if (string.IsNullOrEmpty(_selectedImageModel))
        {
            _imageError = "Choisissez d'abord un modèle d'image dans « Écrire la suite ».";
            return;
        }

        _imagePromptOpen = true;

        if (string.IsNullOrWhiteSpace(_imagePrompt))
            await SuggestImagePromptAsync();
    }

    private async Task SuggestImagePromptAsync()
    {
        _loadingImagePrompt = true;
        try
        {
            _imagePrompt = await GenService.SuggestImagePromptAsync(SlotName, _currentPageIndex);
        }
        catch (Exception ex)
        {
            _imageError = $"Erreur : {ex.Message}";
        }
        finally
        {
            _loadingImagePrompt = false;
        }
    }

    /// Renders the illustration with the prompt on screen (the prose is untouched).
    private async Task ConfirmRegenerateImageAsync()
    {
        _imageError = null;
        _regeneratingImage = true;
        try
        {
            var result = await GenService.RegeneratePageImageAsync(
                SlotName, _currentPageIndex, _selectedImageModel, _imagePrompt);
            switch (result)
            {
                case Narratum.Core.Result<string>.Success success:
                    _currentPageImage = success.Value;
                    _imagePromptOpen = false;
                    break;
                case Narratum.Core.Result<string>.Failure failure:
                    // Keep the editor open: a rejected prompt is exactly what the author needs
                    // to reword (content filters, an unwanted framing…).
                    _imageError = failure.Message;
                    break;
            }
        }
        catch (Exception ex)
        {
            _imageError = $"Erreur : {ex.Message}";
        }
        finally
        {
            _regeneratingImage = false;
        }
    }

    private async Task LoadPageHistory()
    {
        _pageHistory = await GenService.GetPageHistoryAsync(SlotName);
        _pageModels = await GenService.GetPageModelsAsync(SlotName);
    }

    private async Task GoPrev()
    {
        if (!AtFirst) await LoadPage(_pageHistory[CurrentPos - 1]);
    }

    private async Task GoNext()
    {
        if (!AtLast) await LoadPage(_pageHistory[CurrentPos + 1]);
    }

    private async Task LoadPage(int pageIndex)
    {
        _currentPageIndex = pageIndex;
        _editing = false;
        _imageError = null;
        _imagePromptOpen = false;
        _imagePrompt = string.Empty;

        var pageResult = await GenService.LoadPageAsync(SlotName, pageIndex);
        pageResult.Match(
            onSuccess: page =>
            {
                _currentNarrative = page.NarrativeText;
                _currentPageModel = page.ModelUsed;
                _currentPageIntent = page.IntentDescription;
                // Default the model selector to the model this page was generated with.
                if (!string.IsNullOrWhiteSpace(page.ModelUsed) && page.ModelUsed != "N/A")
                    _selectedModel = ResolveSelectedModel(page.ModelUsed);
                return string.Empty;
            },
            onFailure: error => _errorMessage = error);

        await LoadTraces(pageIndex);
        await LoadChoices(pageIndex);
        await LoadCharacters(pageIndex);
        await LoadSecrets(pageIndex);
        await LoadImage(pageIndex);
    }

    private async Task RunGenerationAsync(string intent)
    {
        _isGenerating = true;
        _errorMessage = string.Empty;
        _imageError = null;
        _currentNarrative = string.Empty;
        _choices = Array.Empty<StoryChoice>();          // hide stale choices while the next page streams
        _characters = Array.Empty<CharacterProfile>();  // and the previous roster
        _secrets = Array.Empty<StorySecret>();          // and the previous secrets
        _currentPageImage = null;                       // and the previous image

        try
        {
            // Throttle re-renders so a fast token stream doesn't flood the circuit.
            var lastRender = DateTime.UtcNow;
            var imageModel = string.IsNullOrEmpty(_selectedImageModel) ? null : _selectedImageModel;
            await foreach (var chunk in GenService.GenerateNextPageStreamingAsync(SlotName, intent, _selectedModel, imageModel))
            {
                _currentNarrative += chunk;

                var now = DateTime.UtcNow;
                if ((now - lastRender).TotalMilliseconds >= 60)
                {
                    lastRender = now;
                    StateHasChanged();
                }
            }

            // Generation + save completed successfully.
            _currentPageModel = _selectedModel; // the page just generated used this model
            _userIntent = string.Empty; // Clear input
            await LoadPageHistory();    // Refresh timeline
            if (_pageHistory.Any())
                _currentPageIndex = _pageHistory.Max();
            await LoadTraces(_currentPageIndex);     // Expert data for the new page
            await LoadChoices(_currentPageIndex);    // Next-step choices for the new page
            await LoadCharacters(_currentPageIndex); // Character roster for the new page
            await LoadSecrets(_currentPageIndex);    // Revealed/hidden secrets for the new page
            await LoadImage(_currentPageIndex);      // Generated image for the new page

            // Reflect the new page count in the sidebar.
            _library = await LibraryService.ListStoriesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            _isGenerating = false;
        }
    }
}
