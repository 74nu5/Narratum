@page "/generation/{SlotName}"
@rendermode InteractiveServer
@inject IGenerationService GenService
@inject NavigationManager Navigation
@inject ExpertModeService ExpertMode
@inject ModelCatalogService ModelCatalog
@inject AzureFoundryState AzureState
@inject Narratum.Orchestration.Llm.ILlmClient LlmClient
@using Narratum.Orchestration.Models
@using Narratum.Llm.Azure
@implements IDisposable

<PageTitle>Génération - Narratum</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24">
    <FluentLabel Typo="Typography.H2">📖 @_displayTitle</FluentLabel>

    <div class="gen-layout">
        @* LEFT: composer / controls, laid out vertically *@
        <aside class="gen-sidebar">
            <FluentCard Class="composer-card">
                @* Own flex column so the intent field grows to fill the card's height. *@
                <div class="composer-body">
                    <FluentLabel Typo="Typography.H4">✍️ Composer la suite</FluentLabel>

                    @if (_subscriptions.Count > 0)
                    {
                        <FluentSelect TOption="AzureSubscriptionInfo"
                                      Items="_subscriptions"
                                      OptionValue="@(s => s.SubscriptionId)"
                                      OptionText="@(s => $"☁️ {s.DisplayName}")"
                                      Value="_currentSubscription"
                                      ValueChanged="OnSubscriptionChanged"
                                      Disabled="@(_subscriptions.Count < 2)"
                                      Label="Souscription Azure"
                                      Style="width: 100%;" />
                    }

                    <FluentSelect TOption="ModelOption"
                                  Items="_models"
                                  OptionValue="@(m => m.Id)"
                                  OptionText="@(m => m.Label)"
                                  @bind-Value="_selectedModel"
                                  Label="Modèle (local ou cloud)"
                                  Style="width: 100%;" />

                    <div class="model-inuse">▶ Prochaine page : <strong>@ModelBadge(_selectedModel)</strong></div>

                    <FluentTextArea @bind-Value="_userIntent" Label="Que doit-il se passer ensuite ?"
                                  Class="composer-intent"
                                  Style="width: 100%;"
                                  Placeholder="Ex: Les personnages découvrent une porte secrète..." />

                    <FluentButton Appearance="Appearance.Accent" @onclick="GenerateNextPage"
                                Disabled="@(_isGenerating || string.IsNullOrWhiteSpace(_userIntent))"
                                Style="width: 100%;">
                        ✨ Générer la suite
                    </FluentButton>

                    <FluentButton Appearance="Appearance.Neutral" @onclick='() => Navigation.NavigateTo("/")'
                                Style="width: 100%;">
                        ← Retour au dashboard
                    </FluentButton>

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <FluentMessageBar Intent="MessageIntent.Error">@_errorMessage</FluentMessageBar>
                    }
                </div>
            </FluentCard>
        </aside>

        @* RIGHT: timeline, page text and expert traces *@
        <div class="gen-main">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="24">
                @* Timeline *@
                <FluentCard>
                    <FluentLabel Typo="Typography.H4">Timeline</FluentLabel>
                    <FluentStack Orientation="Orientation.Horizontal" Wrap="true" HorizontalGap="8">
                        @foreach (var pageIdx in _pageHistory)
                        {
                            <FluentButton Appearance="@(pageIdx == _currentPageIndex ? Appearance.Accent : Appearance.Neutral)"
                                          @onclick="() => LoadPage(pageIdx)"
                                          Title="@(string.IsNullOrWhiteSpace(PageModel(pageIdx)) ? "état initial" : ModelBadge(PageModel(pageIdx)))">
                                @ModelDisplay.Icon(PageModel(pageIdx)) Page @pageIdx
                            </FluentButton>
                        }
                    </FluentStack>
                </FluentCard>

                @* Current page content *@
                <FluentCard Style="min-height: 300px;">
                    @if (_isGenerating)
                    {
                        <div class="model-badge model-badge--live">⏳ Génération avec <strong>@ModelBadge(_selectedModel)</strong></div>
                    }
                    else if (!string.IsNullOrEmpty(_currentNarrative) && !string.IsNullOrEmpty(_currentPageModel))
                    {
                        <div class="model-badge">Généré avec <strong>@ModelBadge(_currentPageModel)</strong></div>
                    }

                    @if (_isGenerating && string.IsNullOrEmpty(_currentNarrative))
                    {
                        @* Waiting for the first token *@
                        <FluentStack Orientation="Orientation.Vertical" VerticalAlignment="VerticalAlignment.Center" Style="min-height: 200px;">
                            <FluentProgressRing />
                            <FluentLabel>Génération en cours...</FluentLabel>
                        </FluentStack>
                    }
                    else if (!string.IsNullOrEmpty(_currentNarrative))
                    {
                        @* Streams in live; a caret shows while more text is arriving *@
                        <div style="white-space: pre-wrap; line-height: 1.6;">@_currentNarrative@(_isGenerating ? "▋" : string.Empty)</div>
                    }
                    else
                    {
                        <FluentLabel>Aucune page générée. Saisissez une intention et cliquez sur "Générer".</FluentLabel>
                    }
                </FluentCard>

                @* Next-step choices: pick one to drive the following page *@
                @if (!_isGenerating && _choices.Count > 0)
                {
                    <FluentCard>
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
                            <FluentLabel Typo="Typography.H4">Que faites-vous ?</FluentLabel>
                            <div class="choice-list">
                                @foreach (var choice in _choices)
                                {
                                    <button type="button" class="choice-button"
                                            @onclick="() => ChooseAndContinue(choice)"
                                            disabled="@_isGenerating">
                                        <span class="choice-text">@choice.Text</span>
                                        <span class="choice-desc">@choice.Description</span>
                                    </button>
                                }
                            </div>
                        </FluentStack>
                    </FluentCard>
                }

                @* Expert mode: behind-the-scenes agent traces (hidden from normal readers) *@
                @if (ExpertMode.IsExpertModeEnabled && _agentTraces.Count > 0)
                {
                    <FluentCard>
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
                            <FluentLabel Typo="Typography.H4">🔧 Coulisses des agents</FluentLabel>
                            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">
                                Ce que chaque agent spécialisé a produit pour cette page. Le lecteur ne voit que la prose du Narrateur.
                            </FluentLabel>
                            @foreach (var trace in _agentTraces)
                            {
                                <details class="agent-trace">
                                    <summary>
                                        <span class="agent-name">@trace.Agent</span>
                                        <span class="agent-role">@trace.Role</span>
                                        <span class="agent-ms">@trace.DurationMs.ToString("F0") ms</span>
                                    </summary>
                                    <div class="agent-output">@trace.Output</div>
                                </details>
                            }
                        </FluentStack>
                    </FluentCard>
                }
            </FluentStack>
        </div>
    </div>
</FluentStack>

@code {
    [Parameter] public string SlotName { get; set; } = string.Empty;

    private List<int> _pageHistory = new();
    private int _currentPageIndex = 0;
    private string _currentNarrative = string.Empty;
    private string _userIntent = string.Empty;
    private bool _isGenerating = false;
    private string _errorMessage = string.Empty;
    private string _displayTitle = string.Empty;
    private IReadOnlyList<AgentTraceInfo> _agentTraces = Array.Empty<AgentTraceInfo>();
    private IReadOnlyDictionary<int, string?> _pageModels = new Dictionary<int, string?>();
    private IReadOnlyList<StoryChoice> _choices = Array.Empty<StoryChoice>();
    private IReadOnlyList<ModelOption> _models = ModelSelectionService.AvailableModels;
    private IReadOnlyList<ModelOption> _localModels = Array.Empty<ModelOption>();
    private string _selectedModel = ModelSelectionService.AvailableModels[0].Id;
    private string? _currentPageModel;
    private IReadOnlyList<AzureSubscriptionInfo> _subscriptions = Array.Empty<AzureSubscriptionInfo>();
    private string? _currentSubscription;

    // Human-readable "provider · model" for a stored model id (local Foundry or azure:*).
    private string ModelBadge(string? modelId) => ModelDisplay.Badge(modelId, _models);

    private string? PageModel(int pageIndex) => _pageModels.GetValueOrDefault(pageIndex);

    protected override async Task OnInitializedAsync()
    {
        // Re-render when the Expert toggle (in the layout) changes.
        ExpertMode.OnExpertModeToggled += HandleExpertToggled;

        _displayTitle = await GenService.GetDisplayNameAsync(SlotName);
        _localModels = await ModelCatalog.GetModelsAsync(LlmClient);
        _subscriptions = await AzureState.GetSubscriptionsAsync();
        _currentSubscription = AzureState.CurrentSubscriptionId;
        await RebuildModelListAsync();
        _selectedModel = _models.FirstOrDefault()?.Id ?? _selectedModel;

        await LoadPageHistory();

        // Load latest page if exists
        if (_pageHistory.Any())
        {
            _currentPageIndex = _pageHistory.Max();
            await LoadPage(_currentPageIndex);
        }
    }

    // The stored model may be an alias (older story) while the catalogue uses concrete
    // variant ids — map it to a real option, else keep the first available model.
    private string ResolveSelectedModel(string stored)
    {
        if (_models.Any(m => m.Id == stored)) return stored;
        var byAlias = _models.FirstOrDefault(m => m.Id.StartsWith(stored, StringComparison.OrdinalIgnoreCase));
        return byAlias?.Id ?? _models.FirstOrDefault()?.Id ?? stored;
    }

    // Merge local Foundry models with the current Azure subscription's chat deployments.
    private async Task RebuildModelListAsync()
    {
        var azureModels = await AzureState.GetAzureModelsAsync();
        _models = [.. _localModels, .. azureModels];
    }

    private async Task OnSubscriptionChanged(string? subscriptionId)
    {
        if (string.IsNullOrEmpty(subscriptionId))
            return;

        _currentSubscription = subscriptionId;
        AzureState.SetCurrentSubscription(subscriptionId);
        await RebuildModelListAsync();
    }

    private void HandleExpertToggled() => InvokeAsync(StateHasChanged);

    public void Dispose() => ExpertMode.OnExpertModeToggled -= HandleExpertToggled;

    private async Task LoadTraces(int pageIndex)
    {
        _agentTraces = await GenService.GetAgentTraceAsync(SlotName, pageIndex);
    }

    private async Task LoadChoices(int pageIndex)
    {
        _choices = await GenService.GetPageChoicesAsync(SlotName, pageIndex);
    }

    private async Task ChooseAndContinue(StoryChoice choice)
    {
        _userIntent = choice.Text;
        await GenerateNextPage();
    }

    private async Task LoadPageHistory()
    {
        _pageHistory = await GenService.GetPageHistoryAsync(SlotName);
        _pageModels = await GenService.GetPageModelsAsync(SlotName);
    }

    private async Task LoadPage(int pageIndex)
    {
        _currentPageIndex = pageIndex;
        
        var pageResult = await GenService.LoadPageAsync(SlotName, pageIndex);
        pageResult.Match(
            onSuccess: page =>
            {
                _currentNarrative = page.NarrativeText;
                _currentPageModel = page.ModelUsed;
                // Default the model selector to the model this page was generated with.
                if (!string.IsNullOrWhiteSpace(page.ModelUsed) && page.ModelUsed != "N/A")
                    _selectedModel = ResolveSelectedModel(page.ModelUsed);
                return string.Empty;
            },
            onFailure: error => _errorMessage = error);

        await LoadTraces(pageIndex);
        await LoadChoices(pageIndex);
    }

    private async Task GenerateNextPage()
    {
        _isGenerating = true;
        _errorMessage = string.Empty;
        _currentNarrative = string.Empty;
        _choices = Array.Empty<StoryChoice>(); // hide stale choices while the next page streams
        var intent = _userIntent;

        try
        {
            // Throttle re-renders so a fast token stream doesn't flood the circuit.
            var lastRender = DateTime.UtcNow;
            await foreach (var chunk in GenService.GenerateNextPageStreamingAsync(SlotName, intent, _selectedModel))
            {
                _currentNarrative += chunk;

                var now = DateTime.UtcNow;
                if ((now - lastRender).TotalMilliseconds >= 60)
                {
                    lastRender = now;
                    StateHasChanged();
                }
            }

            // Generation + save completed successfully.
            _currentPageModel = _selectedModel; // the page just generated used this model
            _userIntent = string.Empty; // Clear input
            await LoadPageHistory();    // Refresh timeline
            if (_pageHistory.Any())
                _currentPageIndex = _pageHistory.Max();
            await LoadTraces(_currentPageIndex);  // Expert data for the new page
            await LoadChoices(_currentPageIndex); // Next-step choices for the new page
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            _isGenerating = false;
        }
    }
}
