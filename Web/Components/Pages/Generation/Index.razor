@page "/generation/{SlotName}"
@rendermode InteractiveServer
@inject IGenerationService GenService
@inject NavigationManager Navigation
@inject ExpertModeService ExpertMode
@implements IDisposable

<PageTitle>Génération - Narratum</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24">
    <FluentLabel Typo="Typography.H2">📖 @_displayTitle</FluentLabel>

    @* Timeline *@
    <FluentCard>
        <FluentLabel Typo="Typography.H4">Timeline</FluentLabel>
        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" HorizontalGap="8">
            @foreach (var pageIdx in _pageHistory)
            {
                <FluentButton Appearance="@(pageIdx == _currentPageIndex ? Appearance.Accent : Appearance.Neutral)"
                              @onclick="() => LoadPage(pageIdx)">
                    Page @pageIdx
                </FluentButton>
            }
        </FluentStack>
    </FluentCard>

    @* Current page content *@
    <FluentCard Style="min-height: 300px;">
        @if (_isGenerating && string.IsNullOrEmpty(_currentNarrative))
        {
            @* Waiting for the first token *@
            <FluentStack Orientation="Orientation.Vertical" VerticalAlignment="VerticalAlignment.Center" Style="min-height: 200px;">
                <FluentProgressRing />
                <FluentLabel>Génération en cours...</FluentLabel>
            </FluentStack>
        }
        else if (!string.IsNullOrEmpty(_currentNarrative))
        {
            @* Streams in live; a caret shows while more text is arriving *@
            <div style="white-space: pre-wrap; line-height: 1.6;">@_currentNarrative@(_isGenerating ? "▋" : string.Empty)</div>
        }
        else
        {
            <FluentLabel>Aucune page générée. Saisissez une intention et cliquez sur "Générer".</FluentLabel>
        }
    </FluentCard>

    @* Expert mode: behind-the-scenes agent traces (hidden from normal readers) *@
    @if (ExpertMode.IsExpertModeEnabled && _agentTraces.Count > 0)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
                <FluentLabel Typo="Typography.H4">🔧 Coulisses des agents</FluentLabel>
                <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">
                    Ce que chaque agent spécialisé a produit pour cette page. Le lecteur ne voit que la prose du Narrateur.
                </FluentLabel>
                @foreach (var trace in _agentTraces)
                {
                    <details class="agent-trace">
                        <summary>
                            <span class="agent-name">@trace.Agent</span>
                            <span class="agent-role">@trace.Role</span>
                            <span class="agent-ms">@trace.DurationMs.ToString("F0") ms</span>
                        </summary>
                        <div class="agent-output">@trace.Output</div>
                    </details>
                }
            </FluentStack>
        </FluentCard>
    }

    @* Intent input *@
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
            <FluentTextArea @bind-Value="_userIntent" Label="Que doit-il se passer ensuite ?" Rows="3"
                          Placeholder="Ex: Les personnages découvrent une porte secrète..." />
            <FluentSelect TOption="string" @bind-SelectedOption="_selectedModel" Label="Modèle (pour cette page)"
                          Style="max-width: 360px;">
                @foreach (var m in ModelSelectionService.AvailableModels)
                {
                    <FluentOption Value="@m.Id">@m.Label</FluentOption>
                }
            </FluentSelect>
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12">
                <FluentButton Appearance="Appearance.Accent" @onclick="GenerateNextPage" 
                            Disabled="@(_isGenerating || string.IsNullOrWhiteSpace(_userIntent))">
                    ✨ Générer la suite
                </FluentButton>
                
                <FluentButton Appearance="Appearance.Neutral" @onclick='() => Navigation.NavigateTo("/")'> 
                    ← Retour au dashboard
                </FluentButton>
            </FluentStack>
        </FluentStack>
    </FluentCard>

    @* Error display *@
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <FluentMessageBar Intent="MessageIntent.Error">@_errorMessage</FluentMessageBar>
    }
</FluentStack>

@code {
    [Parameter] public string SlotName { get; set; } = string.Empty;

    private List<int> _pageHistory = new();
    private int _currentPageIndex = 0;
    private string _currentNarrative = string.Empty;
    private string _userIntent = string.Empty;
    private bool _isGenerating = false;
    private string _errorMessage = string.Empty;
    private string _displayTitle = string.Empty;
    private IReadOnlyList<AgentTraceInfo> _agentTraces = Array.Empty<AgentTraceInfo>();
    private string _selectedModel = ModelSelectionService.AvailableModels[0].Id;

    protected override async Task OnInitializedAsync()
    {
        // Re-render when the Expert toggle (in the layout) changes.
        ExpertMode.OnExpertModeToggled += HandleExpertToggled;

        _displayTitle = await GenService.GetDisplayNameAsync(SlotName);
        await LoadPageHistory();

        // Load latest page if exists
        if (_pageHistory.Any())
        {
            _currentPageIndex = _pageHistory.Max();
            await LoadPage(_currentPageIndex);
        }
    }

    private void HandleExpertToggled() => InvokeAsync(StateHasChanged);

    public void Dispose() => ExpertMode.OnExpertModeToggled -= HandleExpertToggled;

    private async Task LoadTraces(int pageIndex)
    {
        _agentTraces = await GenService.GetAgentTraceAsync(SlotName, pageIndex);
    }

    private async Task LoadPageHistory()
    {
        _pageHistory = await GenService.GetPageHistoryAsync(SlotName);
    }

    private async Task LoadPage(int pageIndex)
    {
        _currentPageIndex = pageIndex;
        
        var pageResult = await GenService.LoadPageAsync(SlotName, pageIndex);
        pageResult.Match(
            onSuccess: page =>
            {
                _currentNarrative = page.NarrativeText;
                // Default the model selector to the model this page was generated with.
                if (!string.IsNullOrWhiteSpace(page.ModelUsed) && page.ModelUsed != "N/A")
                    _selectedModel = page.ModelUsed;
                return string.Empty;
            },
            onFailure: error => _errorMessage = error);

        await LoadTraces(pageIndex);
    }

    private async Task GenerateNextPage()
    {
        _isGenerating = true;
        _errorMessage = string.Empty;
        _currentNarrative = string.Empty;
        var intent = _userIntent;

        try
        {
            // Throttle re-renders so a fast token stream doesn't flood the circuit.
            var lastRender = DateTime.UtcNow;
            await foreach (var chunk in GenService.GenerateNextPageStreamingAsync(SlotName, intent, _selectedModel))
            {
                _currentNarrative += chunk;

                var now = DateTime.UtcNow;
                if ((now - lastRender).TotalMilliseconds >= 60)
                {
                    lastRender = now;
                    StateHasChanged();
                }
            }

            // Generation + save completed successfully.
            _userIntent = string.Empty; // Clear input
            await LoadPageHistory();    // Refresh timeline
            if (_pageHistory.Any())
                _currentPageIndex = _pageHistory.Max();
            await LoadTraces(_currentPageIndex); // Expert data for the new page
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            _isGenerating = false;
        }
    }
}
