@page "/library"
@rendermode InteractiveServer
@inject StoryLibraryService LibraryService
@inject IGenerationService GenService
@inject NavigationManager Navigation

<PageTitle>Bibliothèque - Narratum</PageTitle>

<div style="max-width:1120px;margin:0 auto;padding:48px 28px 72px">

    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:12px">
        <div>
            <div class="kicker" style="margin-bottom:10px">Toutes mes histoires</div>
            <h1 style="font-size:42px">Bibliothèque</h1>
        </div>
        <a class="btn btn-accent" href="/wizard" style="flex:none">＋ Nouvelle histoire</a>
    </div>

    @if (_stories is not null)
    {
        <div class="mono" style="font-size:12px;color:var(--text-3);margin-bottom:26px">
            @_stories.Count histoire@(_stories.Count == 1 ? "" : "s") · triées par date de modification
        </div>
    }

    @if (_stories is null)
    {
        <div class="spinner" style="margin:32px auto"></div>
    }
    else
    {
        <div class="card" style="overflow:hidden">
            <div class="lib-row lib-head">
                <span class="eyebrow">Titre</span>
                <span class="eyebrow">Genre</span>
                <span class="eyebrow">Pages</span>
                <span class="eyebrow">Modifiée</span>
                <span class="eyebrow" style="text-align:right">Actions</span>
            </div>

            @if (_stories.Count == 0)
            {
                <div style="padding:48px 22px;text-align:center;font-family:var(--serif);font-size:17px;color:var(--text-3)">
                    Aucune histoire pour l'instant. Créez-en une pour commencer.
                </div>
            }
            else
            {
                @foreach (var story in _stories)
                {
                    <div class="lib-row lib-body">
                        <div style="display:flex;align-items:center;gap:12px;min-width:0">
                            <span style="font-size:19px;flex:none">@StoryVisuals.Icon(story.GenreStyle)</span>
                            @if (_renamingSlot == story.SlotName)
                            {
                                <input class="field" @bind="_renameText" @onkeydown="@(e => OnRenameKeyAsync(e, story.SlotName))"
                                       style="font-family:var(--serif);font-size:17px" autofocus />
                                <button class="btn btn-accent btn-sm" @onclick="() => SaveRenameAsync(story.SlotName)">OK</button>
                                <button class="btn btn-quiet btn-sm" @onclick="() => _renamingSlot = null">✕</button>
                            }
                            else
                            {
                                <span style="font-family:var(--serif);font-size:18px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@story.DisplayName</span>
                                <button class="btn btn-quiet btn-sm lib-rename" title="Renommer" style="padding:2px 6px"
                                        @onclick="() => StartRename(story)">✎</button>
                            }
                        </div>
                        <div><span class="chip">@story.GenreStyle</span></div>
                        <div style="font-size:14px;color:var(--text-2)">@story.PageCount</div>
                        <div class="mono" style="font-size:12px;color:var(--text-3)">@story.LastModified.ToString("dd/MM/yyyy HH:mm")</div>
                        <div style="display:flex;align-items:center;gap:8px;justify-content:flex-end">
                            <a class="btn btn-accent btn-sm" href="@($"/generation/{story.SlotName}")">▶ Continuer</a>
                            <a class="btn btn-soft btn-sm" href="@($"/reader/{story.SlotName}")">📖 Lire</a>
                            <a class="btn btn-soft btn-sm" href="@($"/export/{story.SlotName}/epub")" title="Exporter en EPUB">⤓ EPUB</a>
                            <button class="icon-btn lib-del" title="Supprimer" @onclick="() => _deleteTarget = story">🗑</button>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@if (_deleteTarget is not null)
{
    <div class="overlay" @onclick="() => _deleteTarget = null">
        <div class="modal" style="max-width:400px;padding:26px 26px 22px" @onclick:stopPropagation="true">
            <div class="modal-title" style="margin-bottom:8px">Supprimer l'histoire ?</div>
            <p style="margin:0 0 22px;font-size:14px;line-height:1.55;color:var(--text-2)">
                « <strong style="color:var(--text)">@_deleteTarget.DisplayName</strong> » et toutes ses pages seront
                définitivement supprimées. Cette action est irréversible.
            </p>
            <div style="display:flex;gap:10px;justify-content:flex-end">
                <button class="btn btn-soft" @onclick="() => _deleteTarget = null">Annuler</button>
                <button class="btn btn-danger" @onclick="ConfirmDelete">Supprimer</button>
            </div>
        </div>
    </div>
}

@code {
    private List<StoryEntry>? _stories;
    private StoryEntry? _deleteTarget;
    private string? _renamingSlot;
    private string _renameText = string.Empty;

    protected override async Task OnInitializedAsync() => _stories = await LibraryService.ListStoriesAsync();

    private void StartRename(StoryEntry story)
    {
        _renamingSlot = story.SlotName;
        _renameText = story.DisplayName;
    }

    private async Task OnRenameKeyAsync(KeyboardEventArgs e, string slotName)
    {
        if (e.Key == "Enter")
            await SaveRenameAsync(slotName);
        else if (e.Key == "Escape")
            _renamingSlot = null;
    }

    private async Task SaveRenameAsync(string slotName)
    {
        var name = _renameText.Trim();
        if (name.Length > 0)
        {
            await GenService.RenameStoryAsync(slotName, name);
            _stories = await LibraryService.ListStoriesAsync();
        }

        _renamingSlot = null;
    }

    private async Task ConfirmDelete()
    {
        if (_deleteTarget is null)
            return;

        await LibraryService.DeleteStoryAsync(_deleteTarget.SlotName);
        _deleteTarget = null;
        _stories = await LibraryService.ListStoriesAsync();
    }
}
