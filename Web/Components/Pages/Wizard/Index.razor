@page "/wizard"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IGenerationService GenService
@inject ModelCatalogService ModelCatalog
@inject AzureFoundryState AzureState
@inject Narratum.Orchestration.Llm.ILlmClient LlmClient
@using Narratum.Llm.Azure

<PageTitle>Créer une histoire - Narratum</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24">
    <FluentText Block="true" Size="TextSize.Size700" Weight="TextWeight.Bold">✨ Créer une nouvelle histoire</FluentText>

    @* Step indicator *@
    <FluentCard>
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
            @for (var i = 0; i < this.stepTitles.Length; i++)
            {
                var stepIndex = i;
                <FluentButton Appearance="@(stepIndex == this.currentStep ? ButtonAppearance.Primary : ButtonAppearance.Default)"
                              Disabled="@(stepIndex > this.currentStep)"
                              @onclick="() => this.currentStep = stepIndex">
                    @(stepIndex + 1). @this.stepTitles[stepIndex]
                </FluentButton>
            }
        </FluentStack>
    </FluentCard>
    
    @* Step content *@
    <div>
        @switch (this.currentStep)
        {
            case 0: @* Monde *@
                <WorldEditor @bind-WorldName="this.worldName" @bind-WorldDescription="this.worldDescription" />
                break;
                
            case 1: @* Genre *@
                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
                        <FluentSelect TOption="KeyValuePair<string, string>"
                                      TValue="string"
                                      Items="genreOptions"
                                      OptionValue="@(g => g.Key)"
                                      OptionText="@(g => g.Value)"
                                      @bind-Value="this.genre"
                                      Label="Genre"
                                      Style="width: 100%; max-width: 480px;" />
                        <FluentTextArea Label="Style narratif (optionnel)" @bind-Value="this.narrativeStyle" Style="width: 100%; height: 4.5rem;"
                                      Placeholder="Ex: Épique, sombre, humoristique..." />
                        @if (this.subscriptions.Count > 0)
                        {
                            <FluentSelect TOption="AzureSubscriptionInfo"
                                          TValue="string"
                                          Items="this.subscriptions"
                                          OptionValue="@(s => s.SubscriptionId)"
                                          OptionText="@(s => $"☁️ {s.DisplayName}")"
                                          Value="this.currentSubscription"
                                          ValueChanged="this.OnSubscriptionChanged"
                                          Disabled="@(this.subscriptions.Count < 2)"
                                          Label="Souscription Azure"
                                          Style="width: 100%; max-width: 480px;" />
                        }
                        <FluentSelect TOption="ModelOption"
                                      TValue="string"
                                      Items="this.models"
                                      OptionValue="@(m => m.Id)"
                                      OptionText="@(m => m.Label)"
                                      @bind-Value="this.model"
                                      Label="Modèle de génération (local ou cloud)"
                                      Style="width: 100%; max-width: 480px;" />
                        <div style="font-size: 0.82rem; opacity: 0.75; margin-top: -8px;">
                            ▶ Sera généré avec : <strong>@ModelDisplay.Badge(this.model, this.models)</strong>
                        </div>
                    </FluentStack>
                </FluentCard>
                break;
                
            case 2: @* Personnages *@
                <CharactersEditor @bind-Characters="this.characters" />
                break;
                
            case 3: @* Lieux *@
                <LocationsEditor @bind-Locations="this.locations" />
                break;
                
            case 4: @* Résumé *@
                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
                        <FluentText Block="true" Size="TextSize.Size500" Weight="TextWeight.Semibold">📋 Récapitulatif</FluentText>
                        <FluentText Block="true" Size="TextSize.Size300"><strong>Monde :</strong> @(this.worldName)
                        </FluentText>
                        <FluentText Block="true" Size="TextSize.Size300"><strong>Description :</strong> @(this.worldDescription ?? "Aucune")
                        </FluentText>
                        <FluentText Block="true" Size="TextSize.Size300"><strong>Genre :</strong> @(this.genre)
                        </FluentText>
                        <FluentText Block="true" Size="TextSize.Size300"><strong>Style :</strong> @(this.narrativeStyle ?? "Par défaut")
                        </FluentText>
                        <FluentText Block="true" Size="TextSize.Size300"><strong>Personnages :</strong> @this.characters.Count</FluentText>
                        <FluentText Block="true" Size="TextSize.Size300"><strong>Lieux :</strong> @this.locations.Count</FluentText>

                        @if (this.characters.Count > 0)
                        {
                            <FluentText Block="true" Size="TextSize.Size300"><strong>Liste des personnages :</strong></FluentText>
                            <ul>
                                @foreach (var c in this.characters)
                                {
                                    <li>@c.Name @(string.IsNullOrEmpty(c.Description) ? "" : $"- {c.Description}")</li>
                                }
                            </ul>
                        }
                    </FluentStack>
                </FluentCard>
                break;
        }
    </div>
    
    @* Navigation buttons *@
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" HorizontalAlignment="HorizontalAlignment.End">
        <FluentButton Appearance="ButtonAppearance.Default" @onclick='() => this.Navigation.NavigateTo("/")'> Annuler</FluentButton>

        @if (this.currentStep > 0)
        {
            <FluentButton Appearance="ButtonAppearance.Default" @onclick="this.PreviousStep">← Précédent</FluentButton>
        }

        @if (this.currentStep < this.stepTitles.Length - 1)
        {
            <FluentButton Appearance="ButtonAppearance.Primary" @onclick="this.NextStep" Disabled="@(!this.CanProceed)">
                Suivant →
            </FluentButton>
        }
        else
        {
            <FluentButton Appearance="ButtonAppearance.Primary" @onclick="this.CreateStory" Disabled="@(!this.CanCreate)">
                🚀 Créer l'histoire
            </FluentButton>
        }
    </FluentStack>
</FluentStack>


