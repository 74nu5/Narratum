@page "/wizard"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IGenerationService GenService
@inject ModelCatalogService ModelCatalog
@inject AzureFoundryState AzureState
@inject Narratum.Orchestration.Llm.ILlmClient LlmClient
@using Narratum.Llm.Azure

<PageTitle>Créer une histoire - Narratum</PageTitle>

<div style="max-width:680px;margin:0 auto;padding:44px 28px 72px">

    <div style="text-align:center;margin-bottom:30px">
        <div class="kicker" style="margin-bottom:10px">Nouvel univers</div>
        <h1 style="font-size:40px">Créer une histoire</h1>
    </div>

    @* Stepper *@
    <div style="display:flex;align-items:center;justify-content:center;margin-bottom:34px;flex-wrap:wrap">
        @for (var i = 0; i < this.stepTitles.Length; i++)
        {
            var stepIndex = i;
            var current = stepIndex == this.currentStep;
            var done = stepIndex < this.currentStep;
            <button @onclick="() => this.currentStep = stepIndex"
                    style="display:flex;align-items:center;gap:8px;background:none;border:none;cursor:pointer;padding:6px 14px;@(stepIndex > 0 ? "border-left:1px solid var(--border)" : "")">
                <span style="display:flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;font-family:var(--sans);font-size:11.5px;font-weight:600;flex:none;@(StepDotStyle(current, done))">@(done ? "✓" : (stepIndex + 1).ToString())</span>
                <span style="font-family:var(--sans);font-size:12.5px;font-weight:@(current ? 700 : 500);color:@(current ? "var(--text)" : "var(--text-3)");white-space:nowrap">@this.stepTitles[stepIndex]</span>
            </button>
        }
    </div>

    <div class="card" style="padding:30px 32px;min-height:280px;animation:stepIn .24s ease">
        @switch (this.currentStep)
        {
            case 0:
                <h2 style="font-size:23px;margin-bottom:4px">Le monde</h2>
                <p style="font-size:13px;color:var(--text-3);margin:0 0 24px">Où votre histoire prend-elle racine ?</p>
                <div style="margin-bottom:20px">
                    <label class="fld-label">Nom du monde <span class="fld-req">*</span></label>
                    <input class="field" @bind="this.worldName" @bind:event="oninput" placeholder="Ex : Le Commandement Stargate" />
                </div>
                <div>
                    <label class="fld-label">Description du monde</label>
                    <textarea class="field" @bind="this.worldDescription" style="min-height:120px" placeholder="Ambiance, époque, règles, ton…"></textarea>
                </div>
                break;

            case 1:
                <h2 style="font-size:23px;margin-bottom:4px">Genre &amp; style</h2>
                <p style="font-size:13px;color:var(--text-3);margin:0 0 24px">La couleur narrative et le moteur de génération.</p>
                <div style="margin-bottom:20px">
                    <label class="fld-label">Genre</label>
                    <select class="field" @bind="this.genre">
                        @foreach (var g in genreOptions)
                        {
                            <option value="@g.Key">@g.Value</option>
                        }
                    </select>
                </div>
                <div style="margin-bottom:20px">
                    <label class="fld-label">Style narratif (optionnel)</label>
                    <input class="field" @bind="this.narrativeStyle" placeholder="Ex : Épique, sombre, humoristique…" />
                </div>
                @if (this.subscriptions.Count > 0)
                {
                    <div style="margin-bottom:20px">
                        <label class="fld-label">Souscription Azure</label>
                        <select class="field" @bind="this.currentSubscription" @bind:after="OnSubscriptionChanged" disabled="@(this.subscriptions.Count < 2)">
                            @foreach (var s in this.subscriptions)
                            {
                                <option value="@s.SubscriptionId">☁ @s.DisplayName</option>
                            }
                        </select>
                    </div>
                }
                <div>
                    <label class="fld-label">Modèle de génération (local ou cloud)</label>
                    <select class="field" @bind="this.model">
                        @foreach (var m in this.models)
                        {
                            <option value="@m.Id">@m.Label</option>
                        }
                    </select>
                    <div style="margin-top:10px;font-size:12px;color:var(--text-3)">▸ Sera généré avec : <strong style="color:var(--text-2)">@ModelDisplay.Badge(this.model, this.models)</strong></div>
                </div>
                break;

            case 2:
                <h2 style="font-size:23px;margin-bottom:4px">Personnages</h2>
                <p style="font-size:13px;color:var(--text-3);margin:0 0 22px">Qui peuplera votre récit ? (facultatif)</p>
                <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:16px">
                    @foreach (var c in this.characters)
                    {
                        <div class="editor-row">
                            <div><label class="fld-label">Nom</label><input class="field" @bind="c.Name" placeholder="Nom" /></div>
                            <div><label class="fld-label">Description</label><input class="field" @bind="c.Description" placeholder="Rôle, traits…" /></div>
                            <button class="icon-btn editor-del" title="Retirer" @onclick="() => this.characters.Remove(c)">✕</button>
                        </div>
                    }
                </div>
                <button class="btn btn-dashed" @onclick="() => this.characters.Add(new())">＋ Ajouter un personnage</button>
                break;

            case 3:
                <h2 style="font-size:23px;margin-bottom:4px">Lieux</h2>
                <p style="font-size:13px;color:var(--text-3);margin:0 0 22px">Les décors marquants de l'aventure. (facultatif)</p>
                <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:16px">
                    @foreach (var l in this.locations)
                    {
                        <div class="editor-row">
                            <div><label class="fld-label">Nom du lieu</label><input class="field" @bind="l.Name" placeholder="Nom" /></div>
                            <div><label class="fld-label">Description</label><input class="field" @bind="l.Description" placeholder="Atmosphère, détails…" /></div>
                            <button class="icon-btn editor-del" title="Retirer" @onclick="() => this.locations.Remove(l)">✕</button>
                        </div>
                    }
                </div>
                <button class="btn btn-dashed" @onclick="() => this.locations.Add(new())">＋ Ajouter un lieu</button>
                break;

            case 4:
                <h2 style="font-size:23px;margin-bottom:4px">Récapitulatif</h2>
                <p style="font-size:13px;color:var(--text-3);margin:0 0 24px">Un dernier regard avant de donner vie à l'histoire.</p>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px 26px;margin-bottom:22px">
                    <div><div class="eyebrow" style="margin-bottom:3px">Monde</div><div style="font-family:var(--serif);font-size:17px;color:var(--text)">@(string.IsNullOrWhiteSpace(this.worldName) ? "— sans nom —" : this.worldName)</div></div>
                    <div><div class="eyebrow" style="margin-bottom:3px">Genre</div><div style="font-family:var(--serif);font-size:17px;color:var(--text)">@this.genre</div></div>
                    <div style="grid-column:1/-1"><div class="eyebrow" style="margin-bottom:3px">Description</div><div style="font-family:var(--serif);font-size:15px;color:var(--text-2);line-height:1.5">@(string.IsNullOrWhiteSpace(this.worldDescription) ? "Aucune description." : this.worldDescription)</div></div>
                    <div><div class="eyebrow" style="margin-bottom:3px">Style</div><div style="font-family:var(--serif);font-size:15px;color:var(--text-2)">@(string.IsNullOrWhiteSpace(this.narrativeStyle) ? "—" : this.narrativeStyle)</div></div>
                    <div><div class="eyebrow" style="margin-bottom:3px">Modèle</div><div style="font-family:var(--serif);font-size:15px;color:var(--text-2)">@ModelDisplay.Badge(this.model, this.models)</div></div>
                </div>
                <div style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap">
                    <span class="chip" style="text-transform:none;letter-spacing:0;font-size:12.5px;padding:6px 13px;background:var(--surface-2)">👥 @NamedCharacters.Count personnage(s)</span>
                    <span class="chip" style="text-transform:none;letter-spacing:0;font-size:12.5px;padding:6px 13px;background:var(--surface-2)">📍 @NamedLocations.Count lieu(x)</span>
                </div>
                @if (NamedCharacters.Count > 0)
                {
                    <div class="eyebrow" style="margin-bottom:8px">Distribution</div>
                    <div style="display:flex;flex-direction:column;gap:6px">
                        @foreach (var c in NamedCharacters)
                        {
                            <div style="font-family:var(--serif);font-size:15px;color:var(--text-2)"><strong style="color:var(--text)">@c.Name</strong>@(string.IsNullOrWhiteSpace(c.Description) ? "" : $" — {c.Description}")</div>
                        }
                    </div>
                }
                break;
        }
    </div>

    <div style="display:flex;align-items:center;gap:12px;margin-top:24px">
        <a class="btn btn-quiet" href="/">Annuler</a>
        <div style="flex:1"></div>
        @if (this.currentStep > 0)
        {
            <button class="btn btn-ghost" @onclick="this.PreviousStep">← Précédent</button>
        }
        @if (this.currentStep < this.stepTitles.Length - 1)
        {
            <button class="btn btn-accent" @onclick="this.NextStep" disabled="@(!this.CanProceed)">Suivant →</button>
        }
        else
        {
            <button class="btn btn-accent" @onclick="this.CreateStory" disabled="@(!this.CanCreate)">✦ Créer l'histoire</button>
        }
    </div>
</div>
