@page "/config"
@rendermode InteractiveServer
@inject ModelSelectionService ModelService
@inject ModelCatalogService ModelCatalog
@inject Narratum.Orchestration.Llm.ILlmClient LlmClient
@inject NavigationManager Navigation

<PageTitle>Configuration - Narratum</PageTitle>

<div style="max-width:720px;margin:0 auto;padding:48px 28px 72px">

    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:28px">
        <div>
            <div class="kicker" style="margin-bottom:10px">Réglages</div>
            <h1 style="font-size:38px">Configuration LLM</h1>
        </div>
        <a class="btn btn-ghost" href="/">← Dashboard</a>
    </div>

    <div class="card" style="padding:26px 28px;margin-bottom:20px">
        <h2 style="font-size:21px;margin-bottom:4px">Modèle de narration</h2>
        <p style="font-size:13px;color:var(--text-3);margin:0 0 18px;line-height:1.55">
            Modèle par défaut de session. Chaque histoire choisit son modèle à la création,
            et chaque page peut le changer depuis l'écran de génération.
        </p>
        <label class="fld-label">Modèle</label>
        <select class="field" style="max-width:480px" @bind="_selectedModel">
            @foreach (var m in _selectableModels)
            {
                <option value="@m.Id">@m.Label</option>
            }
        </select>

        @if (_selectedModel == "custom")
        {
            <div style="margin-top:14px">
                <label class="fld-label">Nom du modèle personnalisé</label>
                <input class="field" style="max-width:400px" @bind="_customModel" placeholder="Ex : llama-3.2" />
            </div>
        }

        <div style="margin-top:18px">
            <button class="btn btn-accent" @onclick="SaveConfig">💾 Sauvegarder</button>
        </div>
        @if (_saved)
        {
            <div class="msg msg-success" style="margin-top:14px;display:inline-block">✓ Configuration sauvegardée !</div>
        }
    </div>

    <div class="card" style="padding:26px 28px;margin-bottom:20px">
        <h2 style="font-size:21px;margin-bottom:14px">Informations système</h2>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:14px;color:var(--text-2)">
            <div><strong style="color:var(--text)">Modèle actuel :</strong> @ModelService.CurrentNarratorModel</div>
            <div><strong style="color:var(--text)">Provider :</strong> Foundry Local</div>
            <div><strong style="color:var(--text)">Endpoint :</strong> <span class="mono">http://localhost:5272</span></div>
        </div>
    </div>

    <div class="card" style="padding:26px 28px">
        <h2 style="font-size:21px;margin-bottom:14px">Test de connexion</h2>
        <button class="btn btn-ghost" @onclick="TestConnection" disabled="@_testing">🔌 Tester la connexion LLM</button>
        @if (_testing)
        {
            <div class="spinner" style="margin-top:16px"></div>
        }
        else if (_testResult is not null)
        {
            <div class="msg @(_testSuccess ? "msg-success" : "msg-error")" style="margin-top:14px">@_testResult</div>
        }
    </div>
</div>

@code {
    private string _selectedModel = "Phi-4-mini";
    private string _customModel = string.Empty;
    private bool _saved = false;
    private bool _testing = false;
    private string? _testResult;
    private bool _testSuccess;
    private IReadOnlyList<ModelOption> _models = ModelSelectionService.AvailableModels;
    // The catalogue plus a trailing "custom" sentinel that reveals the free-text field.
    private IReadOnlyList<ModelOption> _selectableModels = ModelSelectionService.AvailableModels;

    protected override async Task OnInitializedAsync()
    {
        _models = await ModelCatalog.GetModelsAsync(LlmClient);
        _selectableModels = _models.Append(new ModelOption("custom", "Modèle personnalisé…")).ToList();

        var current = ModelService.CurrentNarratorModel;
        // Keep the saved model selected if it's a known option; otherwise default to the first.
        _selectedModel = !string.IsNullOrWhiteSpace(current) && _models.Any(m => m.Id == current)
            ? current
            : _models.FirstOrDefault()?.Id ?? "phi-4-mini";
    }

    private void SaveConfig()
    {
        var modelToUse = _selectedModel == "custom" ? _customModel : _selectedModel;
        ModelService.CurrentNarratorModel = modelToUse;
        _saved = true;

        Task.Delay(3000).ContinueWith(_ =>
        {
            _saved = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private async Task TestConnection()
    {
        _testing = true;
        _testResult = null;

        try
        {
            var healthy = await LlmClient.IsHealthyAsync();
            _testSuccess = healthy;
            _testResult = healthy
                ? "✓ Connexion réussie au service Foundry Local"
                : "✗ Service LLM inaccessible — vérifiez que Foundry Local est démarré";
        }
        catch (Exception ex)
        {
            _testSuccess = false;
            _testResult = $"✗ Erreur : {ex.Message}";
        }
        finally
        {
            _testing = false;
        }
    }
}
