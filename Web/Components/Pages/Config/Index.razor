@page "/config"
@rendermode InteractiveServer
@inject ModelSelectionService ModelService
@inject ModelCatalogService ModelCatalog
@inject Narratum.Orchestration.Llm.ILlmClient LlmClient
@inject NavigationManager Navigation

<PageTitle>Configuration - Narratum</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="24">
    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween">
        <FluentLabel Typo="Typography.H2">⚙️ Configuration LLM</FluentLabel>
        <FluentButton Appearance="Appearance.Neutral" @onclick='() => Navigation.NavigateTo("/")'> ← Dashboard</FluentButton>
    </FluentStack>
    
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
            <FluentLabel Typo="Typography.H4">Modèle de narration</FluentLabel>
            <FluentLabel Typo="Typography.Body" Style="opacity:0.7;">
                Modèle par défaut de session. Chaque histoire choisit son modèle à la création,
                et chaque page peut le changer depuis l'écran de génération.
            </FluentLabel>
            <FluentSelect TOption="ModelOption"
                          Items="_selectableModels"
                          OptionValue="@(m => m.Id)"
                          OptionText="@(m => m.Label)"
                          @bind-Value="_selectedModel"
                          Label="Modèle"
                          Style="width: 100%; max-width: 480px;" />
            
            @if (_selectedModel == "custom")
            {
                <FluentTextField @bind-Value="_customModel" Label="Nom du modèle personnalisé" 
                               Placeholder="Ex: llama-3.2" Style="max-width: 400px;" />
            }
            
            <FluentButton Appearance="Appearance.Accent" OnClick="SaveConfig" Style="max-width: 200px;">
                💾 Sauvegarder
            </FluentButton>

            @if (_saved)
            {
                <FluentMessageBar Intent="MessageIntent.Success">✓ Configuration sauvegardée !</FluentMessageBar>
            }
        </FluentStack>
    </FluentCard>

    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
            <FluentLabel Typo="Typography.H4">Informations système</FluentLabel>
            <FluentLabel><strong>Modèle actuel :</strong> @ModelService.CurrentNarratorModel</FluentLabel>
            <FluentLabel><strong>Provider :</strong> Foundry Local</FluentLabel>
            <FluentLabel><strong>Endpoint :</strong> http://localhost:5272</FluentLabel>
        </FluentStack>
    </FluentCard>

    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
            <FluentLabel Typo="Typography.H4">Test de connexion</FluentLabel>
            <FluentButton Appearance="Appearance.Neutral" OnClick="TestConnection" Disabled="@_testing">
                🔌 Tester la connexion LLM
            </FluentButton>
            
            @if (_testing)
            {
                <FluentProgressRing />
            }
            else if (_testResult != null)
            {
                <FluentMessageBar Intent="@(_testSuccess ? MessageIntent.Success : MessageIntent.Error)">
                    @_testResult
                </FluentMessageBar>
            }
        </FluentStack>
    </FluentCard>
</FluentStack>

@code {
    private string _selectedModel = "Phi-4-mini";
    private string _customModel = string.Empty;
    private bool _saved = false;
    private bool _testing = false;
    private string? _testResult;
    private bool _testSuccess;
    private IReadOnlyList<ModelOption> _models = ModelSelectionService.AvailableModels;
    // The catalogue plus a trailing "custom" sentinel that reveals the free-text field.
    private IReadOnlyList<ModelOption> _selectableModels = ModelSelectionService.AvailableModels;

    protected override async Task OnInitializedAsync()
    {
        _models = await ModelCatalog.GetModelsAsync(LlmClient);
        _selectableModels = _models.Append(new ModelOption("custom", "Modèle personnalisé…")).ToList();

        var current = ModelService.CurrentNarratorModel;
        // Keep the saved model selected if it's a known option; otherwise default to the first.
        _selectedModel = !string.IsNullOrWhiteSpace(current) && _models.Any(m => m.Id == current)
            ? current
            : _models.FirstOrDefault()?.Id ?? "phi-4-mini";
    }

    private void SaveConfig()
    {
        var modelToUse = _selectedModel == "custom" ? _customModel : _selectedModel;
        ModelService.CurrentNarratorModel = modelToUse;
        _saved = true;

        Task.Delay(3000).ContinueWith(_ => 
        {
            _saved = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private async Task TestConnection()
    {
        _testing = true;
        _testResult = null;

        try
        {
            var healthy = await LlmClient.IsHealthyAsync();
            _testSuccess = healthy;
            _testResult = healthy
                ? "✓ Connexion réussie au service Foundry Local"
                : "✗ Service LLM inaccessible — vérifiez que Foundry Local est démarré";
        }
        catch (Exception ex)
        {
            _testSuccess = false;
            _testResult = $"✗ Erreur : {ex.Message}";
        }
        finally
        {
            _testing = false;
        }
    }
}

