@inherits LayoutComponentBase
@inject ExpertModeService ExpertMode

<FluentLayout>
    <FluentLayoutItem Area="LayoutArea.Header" Style="padding: 0.5rem 1rem;">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Start" VerticalAlignment="VerticalAlignment.Center">
            <FluentText Size="TextSize.Size600" Weight="TextWeight.Bold" Style="cursor: pointer;" @onclick="@(() => NavigationManager.NavigateTo("/"))">
                ✨ Narratum
            </FluentText>
            <FluentSpacer />
            <StorySwitcher />
            <FluentSpacer />
            <FluentSwitch Label="🔧 Expert" @bind-Value="@ExpertMode.IsExpertModeEnabled" />
            <FluentButton Appearance="ButtonAppearance.Outline" @onclick='() => NavigationManager.NavigateTo("/config")'>
                ⚙️ Config
            </FluentButton>
        </FluentStack>
    </FluentLayoutItem>

    <FluentLayoutItem Area="LayoutArea.Content" Style="padding: 2rem;">
        <div class="page">
            <main>
                @Body
            </main>
        </div>
    </FluentLayoutItem>

    <FluentLayoutItem Area="LayoutArea.Footer" Style="padding: 1rem; border-top: 1px solid var(--colorNeutralStroke2, #e0e0e6);">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween">
            <FluentText Size="TextSize.Size300">Narratum - Générateur d'histoires déterministe</FluentText>
            <SaveIndicator IsSaving="@_isSaving" SaveError="@_saveError" LastSaveTime="@_lastSaveTime" />
        </FluentStack>
    </FluentLayoutItem>
</FluentLayout>

<FluentProviders />

@code {
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    private bool _isSaving = false;
    private bool _saveError = false;
    private DateTime? _lastSaveTime = null;
}
