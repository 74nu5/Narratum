@inherits LayoutComponentBase
@inject ExpertModeService ExpertMode
@inject NavigationManager Navigation

<div class="app-root">
    <header class="appbar">
        <a class="brand" href="/" style="cursor:pointer">
            <span class="brand-mark">N</span>
            <span class="brand-name">Narratum</span>
        </a>
        <div class="spacer"></div>
        <button class="pill @(ExpertMode.IsExpertModeEnabled ? "is-on" : null)" @onclick="ToggleExpert" title="Mode expert">✦ Expert</button>
        <button class="icon-btn" onclick="window.narratumTheme.toggle()" title="Jour / Nuit" type="button">
            <span class="theme-moon">☾</span><span class="theme-sun">☀</span>
        </button>
        <a class="icon-btn" href="/config" title="Réglages">⚙</a>
    </header>

    <main class="appmain">
        @Body
    </main>

    <footer class="appfoot">Narratum — générateur d'histoires déterministe</footer>
</div>

@code {
    private void ToggleExpert() => ExpertMode.IsExpertModeEnabled = !ExpertMode.IsExpertModeEnabled;
}
