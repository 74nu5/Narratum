@* Indicateur d'état de sauvegarde dans le footer *@
<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
    @if (IsSaving)
    {
        <FluentSpinner Style="width: 16px; height: 16px;" />
        <FluentText Size="TextSize.Size300">Sauvegarde en cours...</FluentText>
    }
    else if (SaveError)
    {
        <FluentText Size="TextSize.Size300" Style="color: var(--colorStatusDangerForeground1, #c50f1f);">❌ Erreur de sauvegarde</FluentText>
    }
    else if (LastSaveTime.HasValue)
    {
        <FluentText Size="TextSize.Size300" Style="color: var(--colorStatusSuccessForeground1, #0e700e);">✓ Sauvegardé à @LastSaveTime.Value.ToString("HH:mm:ss")</FluentText>
    }
</FluentStack>

@code {
    [Parameter] public bool IsSaving { get; set; }
    [Parameter] public bool SaveError { get; set; }
    [Parameter] public DateTime? LastSaveTime { get; set; }
}
