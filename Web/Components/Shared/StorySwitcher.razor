@* Composant de sélection rapide d'histoire dans le header *@
@inject StoryLibraryService LibraryService
@inject NavigationManager Navigation

<FluentSelect TOption="StoryEntry"
              Items="@_stories"
              OptionValue="@(s => s.SlotName)"
              OptionText="@(s => s.DisplayName)"
              @bind-SelectedOption="@SelectedStory"
              Placeholder="Sélectionner une histoire..."
              Style="min-width: 200px;" />

@code {
    private List<StoryEntry> _stories = new();
    private StoryEntry? _selectedStory;

    private StoryEntry? SelectedStory
    {
        get => _selectedStory;
        set
        {
            if (value != null && value != _selectedStory)
            {
                _selectedStory = value;
                Navigation.NavigateTo($"/generation/{value.SlotName}");
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _stories = await LibraryService.ListStoriesAsync();
    }
}
