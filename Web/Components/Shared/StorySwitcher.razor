@* Composant de sélection rapide d'histoire dans le header *@
@inject StoryLibraryService LibraryService
@inject NavigationManager Navigation

<FluentSelect TOption="StoryEntry"
              TValue="string"
              Items="@_stories"
              OptionValue="@(s => s.SlotName)"
              OptionText="@(s => s.DisplayName)"
              @bind-Value="@SelectedSlot"
              Placeholder="Sélectionner une histoire..."
              Style="min-width: 200px;" />

@code {
    private List<StoryEntry> _stories = new();
    private string? _selectedSlot;

    private string? SelectedSlot
    {
        get => _selectedSlot;
        set
        {
            if (!string.IsNullOrEmpty(value) && value != _selectedSlot)
            {
                _selectedSlot = value;
                Navigation.NavigateTo($"/generation/{value}");
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _stories = await LibraryService.ListStoriesAsync();
    }
}
